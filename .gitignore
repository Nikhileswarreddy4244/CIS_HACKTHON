# ============================================================
#  Python / Backend
# ============================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Environment variables / secrets  ← NEVER commit these!
.env
.env.local
.env.*.local
*.env

# Flask / FastAPI
instance/
flask_session/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Unit test / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# MyPy
.mypy_cache/

# ============================================================
#  Node / React Frontend
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
frontend/build/
frontend/dist/

# Environment files
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.npm
.yarn/cache
.parcel-cache/
.cache/

# ============================================================
#  Database / Storage
# ============================================================

*.db
*.sqlite
*.sqlite3

# Uploaded / stored files (add exceptions if needed)
uploads/
storage/
backups/

# ============================================================
#  IDEs & Editors
# ============================================================

.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================================
#  OS Files
# ============================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================
