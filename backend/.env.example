# FileVault environment variables
# Copy this file to .env and fill in your values.

# Database (default = SQLite)
DATABASE_URL=sqlite:///./filevault.db
DB_ECHO=False

# Storage directories
STORAGE_DIR=./storage
BACKUP_DIR=./backups

# Backup schedule (cron syntax — default: 2 AM daily)
BACKUP_CRON=0 2 * * *

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security
SECRET_KEY=change-me-in-production
